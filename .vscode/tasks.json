{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "build cpp",
            "command": "C:\\msys64\\mingw64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${workspaceFolder}\\.bin\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "run cpp",
            "type": "shell",
            "command": "${workspaceFolder}\\.bin\\${fileBasenameNoExtension}.exe",
            "dependsOn": "build cpp",
            "group": {
                "kind": "build",
                "isDefault": false
            }
        }
    ],
    "version": "2.0.0"
}